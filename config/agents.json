{
  "defaults": {
    "max_iterations": 20,
    "max_turns": 50,
    "timeout_seconds": 10800,
    "runtime": {
      "adapter": "codex",
      "mode": "app_server"
    },
    "result_mappings": {
      "PASS": { "status": "success", "exit_code": 0, "default_jump": "next" },
      "FAIL": { "status": "failure", "exit_code": 10, "default_jump": "abort" },
      "FIX": { "status": "partial", "exit_code": 0, "default_jump": "prev" },
      "SKIP": { "status": "success", "exit_code": 0, "default_jump": "next" },
      "UNKNOWN": { "status": "unknown", "exit_code": 1, "default_jump": "self" }
    }
  },
  "agents": {
    "product.plan-mode": {
      "mode": "ralph_loop",
      "readonly": true,
      "valid_results": ["PASS", "FAIL"]
    },
    "engineering.software-engineer": {
      "mode": "ralph_loop",
      "valid_results": ["PASS", "FAIL"],
      "supervisor_interval": 2
    },
    "general.task-summarizer": {
      "mode": "resume",
      "readonly": true,
      "valid_results": ["PASS", "SKIP"]
    },
    "engineering.security-audit": {
      "mode": "ralph_loop",
      "readonly": true,
      "valid_results": ["PASS", "FIX", "FAIL"]
    },
    "engineering.security-fix": {
      "mode": "ralph_loop",
      "valid_results": ["PASS", "FIX", "FAIL"]
    },
    "engineering.test-coverage": {
      "mode": "ralph_loop",
      "valid_results": ["PASS", "FIX", "FAIL", "SKIP"]
    },
    "engineering.generic-fix": {
      "mode": "ralph_loop",
      "valid_results": ["PASS", "FIX", "FAIL"]
    },
    "general.documentation-writer": {
      "mode": "once",
      "valid_results": ["PASS", "SKIP"]
    },
    "engineering.validation-review": {
      "mode": "ralph_loop",
      "readonly": true,
      "valid_results": ["PASS", "FAIL"]
    }
  }
}
