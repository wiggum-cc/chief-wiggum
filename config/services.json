{
  "version": "2.0",
  "defaults": {
    "timeout": 300,
    "restart_policy": {
      "on_failure": "skip",
      "max_retries": 2,
      "backoff": {
        "initial": 5,
        "multiplier": 2,
        "max": 300
      }
    },
    "circuit_breaker": {
      "enabled": false,
      "threshold": 5,
      "cooldown": 300,
      "half_open_requests": 1
    }
  },
  "groups": {
    "control": { "description": "Control branch synchronization", "enabled": true },
    "workers": { "description": "Worker scheduling and recovery", "enabled": true },
    "effects": { "description": "Effect outbox processing", "enabled": true }
  },
  "services": [
    {
      "id": "validate-control",
      "phase": "startup",
      "order": 10,
      "required": true,
      "schedule": { "type": "tick" },
      "execution": {
        "type": "function",
        "module": "Indexer.Services.Handlers.Control",
        "function": "validate"
      }
    },
    {
      "id": "control-branch-sync",
      "phase": "periodic",
      "groups": ["control"],
      "schedule": { "type": "interval", "interval": 60, "run_on_startup": true },
      "execution": {
        "type": "function",
        "module": "Indexer.Services.Handlers.ControlBranch",
        "function": "sync"
      },
      "concurrency": { "max_instances": 1, "if_running": "skip" }
    },
    {
      "id": "effect-outbox",
      "phase": "periodic",
      "groups": ["effects"],
      "schedule": { "type": "interval", "interval": 10, "run_on_startup": true },
      "execution": {
        "type": "function",
        "module": "Indexer.Services.Handlers.Effects",
        "function": "drain"
      },
      "concurrency": { "max_instances": 1, "if_running": "skip" }
    },
    {
      "id": "scheduler-tick",
      "phase": "post",
      "order": 30,
      "groups": ["workers"],
      "schedule": { "type": "tick" },
      "execution": {
        "type": "function",
        "module": "Indexer.Services.Handlers.Scheduler",
        "function": "tick"
      }
    },
    {
      "id": "task-spawner",
      "phase": "post",
      "order": 40,
      "groups": ["workers"],
      "depends_on": ["scheduler-tick"],
      "condition": { "env_not_equals": { "INDEXER_RUN_MODE": "resume-only" } },
      "schedule": { "type": "tick" },
      "execution": {
        "type": "function",
        "module": "Indexer.Services.Handlers.Workers",
        "function": "spawn"
      }
    }
  ]
}
