{
  "name": "autofix",
  "description": "Autonomous code improvement: randomly audit, verify, fix, and quality-gate in a loop",
  "steps": [
    {
      "id": "random-audit",
      "agent": "autofix.random-audit",
      "max": 50,
      "readonly": true,
      "config": { "max_iterations": 5, "max_turns": 120 },
      "on_result": {
        "PASS": {
          "jump": "random-audit"
        }
      }
    },
    {
      "id": "verify-fix",
      "agent": "autofix.verify-fix",
      "max": 100,
      "commit_after": false,
      "on_result": {
        "SKIP": {
          "jump": "random-audit"
        }
      }
    },
    {
      "id": "quality-gate",
      "agent": "autofix.quality-gate",
      "max": 100,
      "on_result": {
        "PASS": {
          "jump": "random-audit"
        },
        "FAIL": {
          "jump": "random-audit"
        }
      }
    }
  ]
}
